{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "one-more-dawn",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "One More Dawn: create game post",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      },
      {
        "label": "One More Dawn: force-resolve day",
        "description": "Resolve the current day now (testing)",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/force-resolve"
      },
      {
        "label": "One More Dawn: reset city (new cycle)",
        "description": "Wipe the city and start a new cycle",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/reset"
      },
      {
        "label": "One More Dawn: seed demo state",
        "description": "Load a rich day-5 demo city",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/seed-demo"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  }
}
